# =============================================================================
#  Configuration — copiez ce fichier vers « .env » et adaptez les valeurs.
#  (.env est ignoré par git)
# =============================================================================

# --- Domaine public (routé par Traefik vers le service web) ---
DOMAIN=cpfae.mon-domaine.ci

# --- Traefik (déjà installé sur votre hôte) ---
# Nom EXACT du réseau Docker externe de Traefik (ex. `traefik`, `proxy`, `web`)
TRAEFIK_NETWORK=traefik
# Entrypoint Traefik pour le HTTPS (souvent `websecure`)
TRAEFIK_ENTRYPOINT=websecure
# Nom du certResolver Traefik (ex. `letsencrypt`). Si vous ne faites pas de TLS
# via Traefik, retirez les 2 lignes tls du service web dans docker-compose.yml.
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Base de données MySQL ---
# Générez des mots de passe forts, ex. : openssl rand -base64 24
MYSQL_ROOT_PASSWORD=change-moi-root
MYSQL_DATABASE=cpfae
MYSQL_USER=cpfae
MYSQL_PASSWORD=change-moi

# --- CORS : origines autorisées à appeler l'API (séparées par des virgules).
# En prod, mettez l'URL publique de la PWA (ex. https://cpfae.mon-domaine.ci).
# Vide = même origine uniquement (recommandé derrière le proxy nginx/Traefik).
CORS_ORIGIN=
